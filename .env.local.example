# Email Configuration (Optional - Leave empty for development)
# The contact form will work without SMTP config, but emails won't be sent
# To enable email sending, fill in these values:

# Your email address (where contact form submissions will be sent)
CONTACT_EMAIL=monaldasari2007@gmail.com

# SMTP Configuration (for sending emails)
# Example: Using Gmail
# 1. Enable "Less secure app access" or use "App Passwords" (recommended)
# 2. Use these settings:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Example: Using Brevo (Sendinblue)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-brevo-email
# SMTP_PASS=your-brevo-smtp-key

# Example: Using SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
